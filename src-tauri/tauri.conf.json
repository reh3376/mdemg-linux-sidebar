{
  "productName": "mdemg-sidebar",
  "version": "0.3.0",
  "identifier": "com.reh3376.mdemg-sidebar",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "MDEMG Sidebar",
        "width": 420,
        "height": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright (c) 2026 reh3376",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "longDescription": "Linux system tray companion for MDEMG - Multi-Dimensional Emergent Memory Graph",
    "shortDescription": "MDEMG Linux Sidebar"
  }
}
